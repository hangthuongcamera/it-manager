<!-- Wrapper Chính -->
<div class="bg-white dark:bg-gray-800 p-4 md:p-6 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 relative min-h-[500px]">
    <!-- Toolbar -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
        <div class="relative w-full max-w-xs">
            <input type="text" id="searchInput" placeholder="Tìm kiếm theo tên, IP, MAC..." class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm">
            <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
        </div>
        <div class="flex items-center gap-2 flex-wrap justify-end w-full sm:w-auto">
            <button id="importBtn" class="bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2">
                <i class="fas fa-file-import"></i> Import
            </button>
            <input type="file" id="importFile" class="hidden" accept=".xlsx, .xls">
            <a href="/api/devices/export" class="bg-green-100 hover:bg-green-200 dark:bg-green-900/50 dark:hover:bg-green-900/80 text-green-700 dark:text-green-300 px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2">
                <i class="fas fa-file-export"></i> Export
            </a>
            <button onclick="openDeviceModal()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2">
                <i class="fas fa-plus"></i> Thêm Thiết bị
            </button>
        </div>
    </div>

    <!-- Hiển thị Bảng (PC) -->
    <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-left border-collapse whitespace-nowrap">
            <thead>
                <tr class="bg-gray-50 dark:bg-gray-700/50 text-gray-600 dark:text-gray-300 text-sm border-b border-gray-200 dark:border-gray-700">
                    <th class="p-3 font-medium">Tên thiết bị</th>
                    <th class="p-3 font-medium">Địa chỉ IP</th>
                    <th class="p-3 font-medium">Port</th>
                    <th class="p-3 font-medium">Loại</th>
                    <th class="p-3 font-medium">Tài khoản</th>
                    <th class="p-3 font-medium">Mật khẩu</th>
                    <th class="p-3 font-medium text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody id="desktop-device-list" class="divide-y divide-gray-200 dark:divide-gray-700">
                <!-- Render bằng JS -->
            </tbody>
        </table>
    </div>

    <!-- Hiển thị Dạng Card (Mobile) -->
    <div id="mobile-device-list" class="grid grid-cols-1 gap-4 md:hidden">
        <!-- Render bằng JS -->
    </div>

    <!-- Pagination Controls -->
    <div id="pagination-controls" class="mt-6 flex justify-center items-center gap-1 text-sm">
        <!-- Pagination will be rendered here by JS -->
    </div>
</div>

<!-- Modal Thêm/Sửa -->
<div id="deviceModal" class="fixed inset-0 z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeDeviceModal()"></div>
    <div id="deviceModalContent" class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-2xl relative z-10 mx-4 transform scale-95 transition-transform duration-300">
        <div class="p-5 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
            <h3 id="modalTitle" class="text-lg font-bold text-gray-800 dark:text-white">Thêm Thiết bị</h3>
            <button type="button" onclick="closeDeviceModal()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 focus:outline-none">
                <i class="fas fa-times text-lg"></i>
            </button>
        </div>
        <form id="deviceForm" class="p-5 space-y-4 max-h-[70vh] overflow-y-auto">
            <input type="hidden" id="deviceId">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tên thiết bị <span class="text-red-500">*</span></label>
                    <input type="text" id="deviceName" required placeholder="VD: Core Switch 01" class="w-full input-field">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Loại thiết bị <span class="text-red-500">*</span></label>
                    <select id="deviceType" required class="w-full input-field"></select>
                </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Địa chỉ IP <span class="text-red-500">*</span></label>
                    <input type="text" id="deviceIp" required placeholder="VD: 192.168.1.1" class="w-full input-field">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Port</label>
                    <input type="number" id="devicePort" placeholder="VD: 443" class="w-full input-field">
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Địa chỉ MAC</label>
                <input type="text" id="deviceMac" placeholder="VD: 00:1A:2B:3C:4D:5E" class="w-full input-field">
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tài khoản</label>
                    <input type="text" id="deviceUsername" placeholder="VD: admin" class="w-full input-field">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Mật khẩu</label>
                    <input type="text" id="devicePassword" class="w-full input-field">
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Ghi chú</label>
                <textarea id="deviceNote" rows="3" placeholder="Thông tin thêm về thiết bị" class="w-full input-field"></textarea>
            </div>
            <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-gray-100 dark:border-gray-700">
                <button type="button" onclick="closeDeviceModal()" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 rounded-lg transition-colors focus:outline-none">Hủy</button>
                <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors focus:outline-none flex items-center gap-2">
                    <i class="fas fa-save"></i> Lưu thông tin
                </button>
            </div>
        </form>
    </div>
</div>

<style>.input-field { padding: 0.5rem 0.75rem; background-color: white; border: 1px solid #D1D5DB; border-radius: 0.5rem; width: 100%; } .dark .input-field { background-color: #1F2937; border-color: #4B5563; color: white; } .input-field:focus { outline: none; box-shadow: 0 0 0 2px #3B82F6; }</style>

<script>
    let currentPage = 1;
    let devicesData = [];
    let deviceTypesData = [];
    const desktopList = document.getElementById('desktop-device-list');
    const mobileList = document.getElementById('mobile-device-list');
    const deviceModal = document.getElementById('deviceModal');
    const modalContent = document.getElementById('deviceModalContent');
    const deviceForm = document.getElementById('deviceForm');
    const modalTitle = document.getElementById('modalTitle');

    const openDeviceModal = () => {
        deviceForm.reset();
        document.getElementById('deviceId').value = '';
        modalTitle.textContent = 'Thêm Thiết bị';
        deviceModal.classList.remove('hidden');
        setTimeout(() => { deviceModal.classList.remove('opacity-0'); modalContent.classList.remove('scale-95'); }, 10);
    };

    const closeDeviceModal = () => {
        deviceModal.classList.add('opacity-0');
        modalContent.classList.add('scale-95');
        setTimeout(() => { deviceModal.classList.add('hidden'); }, 300);
    };

    const createDeviceRow = (d) => `
        <tr id="device-row-${d._id}" class="hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors text-sm text-gray-800 dark:text-gray-200">
            <td class="p-3 font-semibold">${d.name}</td>
            <td class="p-3 font-mono text-blue-600 dark:text-blue-400">${d.ip}</td>
            <td class="p-3 font-mono">${d.port || ''}</td>
            <td class="p-3">${d.type}</td>
            <td class="p-3">${d.username || ''}</td>
            <td class="p-3 font-mono">
                <span class="password-text" data-password="${d.password || ''}" data-state="hidden">********</span>
                <button onclick="togglePassword(this)" class="ml-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" title="Hiện/Ẩn mật khẩu"><i class="fas fa-eye"></i></button>
            </td>
            <td class="p-3 text-right whitespace-nowrap">
                <button onclick="editDevice('${d._id}')" class="text-blue-500 hover:text-blue-700 dark:hover:text-blue-400 w-8 h-8 rounded-full hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors" title="Sửa"><i class="fas fa-edit"></i></button>
                <button onclick="requestDelete('${d._id}', '${d.name}')" class="text-red-500 hover:text-red-700 dark:hover:text-red-400 w-8 h-8 rounded-full hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" title="Xóa"><i class="fas fa-trash"></i></button>
            </td>
        </tr>
    `;

    const createDeviceCard = (d) => `
        <div id="device-card-${d._id}" class="bg-gray-50 dark:bg-gray-700/30 p-4 rounded-xl border border-gray-100 dark:border-gray-700 space-y-2">
            <div class="flex justify-between items-start">
                <h4 class="font-bold text-gray-800 dark:text-white">${d.name}</h4>
                <span class="px-2 py-1 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-600 text-gray-700 dark:text-gray-200">${d.type}</span>
            </div>
            <p class="text-sm">IP: <span class="font-mono text-blue-600 dark:text-blue-400">${d.ip}${d.port ? `:${d.port}` : ''}</span></p>
            <p class="text-sm">Tài khoản: <span class="font-mono">${d.username || 'N/A'}</span></p>
            <p class="text-sm font-mono">Mật khẩu: 
                <span class="password-text" data-password="${d.password || ''}" data-state="hidden">********</span>
                <button onclick="togglePassword(this)" class="ml-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" title="Hiện/Ẩn mật khẩu"><i class="fas fa-eye"></i></button>
            </p>
            <div class="pt-3 border-t border-gray-200 dark:border-gray-600 flex justify-end gap-2">
                <button onclick="editDevice('${d._id}')" class="text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/20 px-2 py-1 rounded transition-colors text-sm"><i class="fas fa-edit"></i> Sửa</button>
                <button onclick="requestDelete('${d._id}', '${d.name}')" class="text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 px-2 py-1 rounded transition-colors text-sm"><i class="fas fa-trash"></i> Xóa</button>
            </div>
        </div>
    `;

    const renderDevices = () => {
        if (devicesData.length === 0) {
            const emptyRow = `<tr><td colspan="7" class="p-6 text-center text-gray-500">Chưa có dữ liệu.</td></tr>`;
            const emptyCard = `<div class="p-6 text-center text-gray-500 border border-dashed rounded-xl">Chưa có dữ liệu.</div>`;
            desktopList.innerHTML = emptyRow;
            mobileList.innerHTML = emptyCard;
            return;
        }
        desktopList.innerHTML = devicesData.map(createDeviceRow).join('');
        mobileList.innerHTML = devicesData.map(createDeviceCard).join('');
    };

    const renderPagination = (currentPage, totalPages) => {
        const paginationContainer = document.getElementById('pagination-controls');
        if (totalPages <= 1) {
            paginationContainer.innerHTML = '';
            return;
        }

        let paginationHTML = `
            <button onclick="goToPage(${currentPage - 1})" class="px-3 py-1.5 rounded-md font-medium ${currentPage === 1 ? 'bg-gray-100 dark:bg-gray-700 text-gray-400 cursor-not-allowed' : 'bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700'}" ${currentPage === 1 ? 'disabled' : ''}>
                <i class="fas fa-chevron-left"></i>
            </button>
        `;

        for (let i = 1; i <= totalPages; i++) {
            paginationHTML += `
                <button onclick="goToPage(${i})" class="px-3 py-1.5 rounded-md font-medium ${i === currentPage ? 'bg-blue-600 text-white' : 'bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700'}">${i}</button>
            `;
        }

        paginationHTML += `
            <button onclick="goToPage(${currentPage + 1})" class="px-3 py-1.5 rounded-md font-medium ${currentPage === totalPages ? 'bg-gray-100 dark:bg-gray-700 text-gray-400 cursor-not-allowed' : 'bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700'}" ${currentPage === totalPages ? 'disabled' : ''}>
                <i class="fas fa-chevron-right"></i>
            </button>
        `;

        paginationContainer.innerHTML = paginationHTML;
    };

    const fetchDevices = async (searchTerm = '', page = 1) => {
        try {
            const url = `/api/devices?search=${encodeURIComponent(searchTerm)}&page=${page}`;
            const res = await fetch(url);
            if (!res.ok) throw new Error('Failed to fetch devices');
            const data = await res.json();
            devicesData = data.devices;
            currentPage = data.currentPage;
            renderDevices();
            renderPagination(data.currentPage, data.totalPages);
        } catch (err) {
            showToast(err.message, 'error');
        }
    };

    const fetchDeviceTypes = async () => {
        try {
            const res = await fetch('/api/device-types');
            if (!res.ok) throw new Error('Failed to fetch device types');
            deviceTypesData = await res.json();
            const select = document.getElementById('deviceType');
            select.innerHTML = '<option value="">-- Chọn loại --</option>' + deviceTypesData.map(t => `<option value="${t.name}">${t.name}</option>`).join('');
        } catch (err) {
            showToast(err.message, 'error');
        }
    };

    const saveDevice = async (event) => {
        event.preventDefault();
        const id = document.getElementById('deviceId').value;
        const data = {
            name: document.getElementById('deviceName').value,
            type: document.getElementById('deviceType').value,
            ip: document.getElementById('deviceIp').value,
            port: document.getElementById('devicePort').value || null,
            mac: document.getElementById('deviceMac').value,
            username: document.getElementById('deviceUsername').value,
            password: document.getElementById('devicePassword').value,
            note: document.getElementById('deviceNote').value,
        };

        const method = id ? 'PUT' : 'POST';
        const url = id ? `/api/devices/${id}` : '/api/devices';

        try {
            const res = await fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();
            if (!res.ok) throw new Error(result.message || 'Lỗi lưu dữ liệu');

            if (id) {
                const index = devicesData.findIndex(d => d._id === id);
                showToast('Cập nhật thành công!', 'success');
                fetchDevices(document.getElementById('searchInput').value, currentPage); // Refetch current page
            } else {
                showToast('Đã thêm thiết bị!', 'success');
                fetchDevices(document.getElementById('searchInput').value, 1); // Go to page 1
            }
            closeDeviceModal();
        } catch (err) {
            showToast(err.message, 'error');
        }
    };

    window.editDevice = (id) => {
        const device = devicesData.find(d => d._id === id);
        if (!device) return;

        // Đặt lại form để xóa trạng thái validation cũ (nếu có)
        deviceForm.reset();

        // Điền dữ liệu của thiết bị vào form, xử lý các giá trị null/undefined
        document.getElementById('deviceId').value = device._id;
        document.getElementById('deviceName').value = device.name;
        document.getElementById('deviceType').value = device.type;
        document.getElementById('deviceIp').value = device.ip;
        document.getElementById('devicePort').value = device.port || '';
        document.getElementById('deviceMac').value = device.mac || '';
        document.getElementById('deviceUsername').value = device.username || '';
        document.getElementById('devicePassword').value = device.password || '';
        document.getElementById('deviceNote').value = device.note || '';

        // Cập nhật tiêu đề và mở modal trực tiếp, không gọi lại openDeviceModal()
        modalTitle.textContent = 'Cập nhật thông tin Thiết bị';
        deviceModal.classList.remove('hidden');
        setTimeout(() => { deviceModal.classList.remove('opacity-0'); modalContent.classList.remove('scale-95'); }, 10);
    };

    window.requestDelete = (id, name) => {
        openConfirmDialog('Xóa Thiết Bị', `Bạn có chắc chắn muốn xóa thiết bị <b>${name}</b> không?`, 'danger', async () => {
            try {
                const res = await fetch(`/api/devices/${id}`, { method: 'DELETE' });
                const result = await res.json();
                if (!res.ok) throw new Error(result.message || 'Lỗi khi xóa');
                
                showToast('Đã xóa thiết bị', 'success');
                // Refetch. If it was the last item on the page, go to the previous page.
                if (devicesData.length === 1 && currentPage > 1) {
                    fetchDevices(document.getElementById('searchInput').value, currentPage - 1);
                } else {
                    fetchDevices(document.getElementById('searchInput').value, currentPage);
                }
            } catch (err) {
                showToast(err.message, 'error');
            }
        });
    };

    window.togglePassword = (btn) => {
        const container = btn.parentElement;
        const passText = container.querySelector('.password-text');
        const isHidden = passText.dataset.state === 'hidden';
        if (isHidden) {
            passText.textContent = passText.dataset.password;
            passText.dataset.state = 'visible';
            btn.innerHTML = '<i class="fas fa-eye-slash"></i>';
        } else {
            passText.textContent = '********';
            passText.dataset.state = 'hidden';
            btn.innerHTML = '<i class="fas fa-eye"></i>';
        }
    };

    window.goToPage = (page) => {
        const searchTerm = document.getElementById('searchInput').value;
        fetchDevices(searchTerm, page);
    };

    // --- SEARCH LOGIC ---
    const debounce = (func, delay) => {
        let timeout;
        return (...args) => {
            clearTimeout(timeout);
            timeout = setTimeout(() => func(...args), delay);
        };
    };

    const debouncedFetch = debounce((term) => fetchDevices(term, 1), 300); // Reset to page 1 on search

    document.getElementById('searchInput').addEventListener('input', (e) => {
        debouncedFetch(e.target.value);
    });

    // Import logic
    document.getElementById('importBtn').addEventListener('click', () => document.getElementById('importFile').click());
    document.getElementById('importFile').addEventListener('change', async (event) => {
        const file = event.target.files[0];
        if (!file) return;

        const formData = new FormData();
        formData.append('file', file);

        try {
            const res = await fetch('/api/devices/import', {
                method: 'POST',
                body: formData,
            });
            const result = await res.json();
            if (!res.ok) throw new Error(result.message);
            showToast(result.message, 'success');
            fetchDevices('', 1); // Go to page 1 after import
        } catch (err) {
            showToast(err.message, 'error');
        } finally {
            event.target.value = ''; // Reset input
        }
    });

    deviceForm.addEventListener('submit', saveDevice);
    document.addEventListener('DOMContentLoaded', () => {
        fetchDevices();
        fetchDeviceTypes();
    });
</script>