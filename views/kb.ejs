<!-- Main Layout: 2-column -->
<div class="flex flex-col md:flex-row h-full gap-6">
    <!-- Left Column: Note List -->
    <div class="w-full md:w-1/3 lg:w-1/4 flex-shrink-0">
        <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 h-full flex flex-col">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-lg font-bold text-gray-800 dark:text-white">Ghi chú</h2>
                <button onclick="openNoteModal()" class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-1.5 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2">
                    <i class="fas fa-plus"></i> Thêm
                </button>
            </div>
            <div class="relative mb-4">
                 <input type="text" id="kbSearchInput" placeholder="Tìm ghi chú..." class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm">
                <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
            </div>
            <div id="notes-list" class="flex-1 overflow-y-auto space-y-2 pr-2 -mr-2">
                <!-- Notes will be rendered here by JS -->
            </div>
            <div id="kb-pagination" class="mt-4 flex justify-center items-center space-x-1 text-sm">
                <!-- Pagination controls will be rendered here -->
            </div>
        </div>
    </div>

    <!-- Right Column: Note Content -->
    <div class="w-full md:w-2/3 lg:w-3/4">
        <div id="note-content-wrapper" class="bg-white dark:bg-gray-800 p-4 md:p-6 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 h-full overflow-y-auto">
            <!-- Welcome message -->
            <div id="kb-welcome" class="flex flex-col items-center justify-center h-full text-center text-gray-500 dark:text-gray-400">
                <i class="fas fa-book-open text-5xl mb-4"></i>
                <h3 class="text-xl font-semibold">Chào mừng đến Knowledge Base</h3>
                <p>Chọn một ghi chú bên trái để xem nội dung, hoặc tạo một ghi chú mới.</p>
            </div>
            <!-- Note detail will be rendered here -->
            <div id="kb-detail" class="hidden">
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <h1 id="note-title" class="text-2xl font-bold text-gray-900 dark:text-white"></h1>
                        <div class="mt-2 flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
                            <span id="note-category-badge" class="px-2 py-1 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-700"></span>
                            <span>Cập nhật lần cuối: <span id="note-date"></span></span>
                        </div>
                    </div>
                    <div class="flex-shrink-0">
                        <button id="edit-note-btn" class="text-blue-500 hover:text-blue-700 dark:hover:text-blue-400 w-8 h-8 rounded-full hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors" title="Sửa"><i class="fas fa-edit"></i></button>
                        <button id="delete-note-btn" class="text-red-500 hover:text-red-700 dark:hover:text-red-400 w-8 h-8 rounded-full hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" title="Xóa"><i class="fas fa-trash"></i></button>
                    </div>
                </div>
                <article id="note-body" class="prose dark:prose-invert max-w-none"></article>
            </div>
        </div>
    </div>
</div>

<!-- Modal Add/Edit Note -->
<div id="noteModal" class="fixed inset-0 z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeNoteModal()"></div>
    <div id="noteModalContent" class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-3xl relative z-10 mx-4 transform scale-95 transition-transform duration-300 flex flex-col max-h-[90vh]">
        <div class="p-5 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center flex-shrink-0">
            <h3 id="noteModalTitle" class="text-lg font-bold text-gray-800 dark:text-white">Thêm bài viết</h3>
            <button type="button" onclick="closeNoteModal()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 focus:outline-none">
                <i class="fas fa-times text-lg"></i>
            </button>
        </div>
        <form id="noteForm" class="flex-1 flex flex-col overflow-hidden">
            <!-- Scrollable Body -->
            <div class="p-5 space-y-4 flex-1 overflow-y-auto">
                <input type="hidden" id="noteId">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tiêu đề <span class="text-red-500">*</span></label>
                        <input type="text" id="formNoteTitle" required class="w-full input-field">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Danh mục <span class="text-red-500">*</span></label>
                        <select id="formNoteCategory" required class="w-full input-field"></select>
                    </div>
                </div>
                <div class="min-h-[300px]">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Nội dung (Markdown) <span class="text-red-500">*</span></label>
                    <textarea id="noteEditor"></textarea>
                </div>
            </div>
            <!-- Fixed Footer -->
            <div class="flex justify-end gap-3 p-5 border-t border-gray-100 dark:border-gray-700 flex-shrink-0">
                <button type="button" onclick="closeNoteModal()" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 rounded-lg transition-colors focus:outline-none">Hủy</button>
                <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors focus:outline-none flex items-center gap-2">
                    <i class="fas fa-save"></i> Lưu bài viết
                </button>
            </div>
        </form>
    </div>
</div>

<style>
.prose pre {
    position: relative;
    padding-top: 2.5rem; /* Space for the button */
}
.copy-code-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background-color: #4B5563;
    color: #D1D5DB;
    border: none;
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
    font-size: 0.75rem;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s;
}
.prose pre:hover .copy-code-btn {
    opacity: 1;
}
.dark .EasyMDEContainer .CodeMirror {
    background-color: #1F2937;
    color: #D1D5DB;
}
.dark .editor-toolbar button {
    color: #D1D5DB !important;
}
.dark .editor-toolbar button.active, .dark .editor-toolbar button:hover {
    background: #374151;
    border-color: #4B5563;
}
.input-field { padding: 0.5rem 0.75rem; background-color: white; border: 1px solid #D1D5DB; border-radius: 0.5rem; width: 100%; } .dark .input-field { background-color: #1F2937; border-color: #4B5563; color: white; } .input-field:focus { outline: none; box-shadow: 0 0 0 2px #3B82F6; }
</style>

<script>
    let notesData = [];
    let categoriesData = [];
    let selectedNoteId = null;
    let easymde = null;
    let filteredNotesData = [];
    let currentPage = 1;
    const notesPerPage = 7;

    // DOM Elements
    const notesListEl = document.getElementById('notes-list');
    const kbPaginationEl = document.getElementById('kb-pagination');
    const kbWelcomeEl = document.getElementById('kb-welcome');
    const kbDetailEl = document.getElementById('kb-detail');
    const noteTitleEl = document.getElementById('note-title');
    const noteCategoryBadgeEl = document.getElementById('note-category-badge');
    const noteDateEl = document.getElementById('note-date');
    const noteBodyEl = document.getElementById('note-body');
    const noteModal = document.getElementById('noteModal');
    const noteModalContent = document.getElementById('noteModalContent');
    const noteForm = document.getElementById('noteForm');
    const noteModalTitle = document.getElementById('noteModalTitle');

    // --- MODAL & EDITOR ---
    const openNoteModal = (note = null) => {
        initializeEditor(); // Khởi tạo editor khi modal được mở lần đầu
        if (note) {
            // Edit mode: Populate form with note data
            noteModalTitle.textContent = 'Cập nhật bài viết';
            document.getElementById('noteId').value = note._id;
            document.getElementById('formNoteTitle').value = note.title;
            document.getElementById('formNoteCategory').value = note.category;
            if (easymde) {
                easymde.value(note.content);
            }
        } else {
            // Add mode: Reset form
            noteForm.reset();
            document.getElementById('noteId').value = '';
            noteModalTitle.textContent = 'Thêm bài viết';
            if (easymde) {
                easymde.value('');
            }
        }
        
        noteModal.classList.remove('hidden');
        setTimeout(() => { noteModal.classList.remove('opacity-0'); noteModalContent.classList.remove('scale-95'); }, 10);
    };

    const closeNoteModal = () => {
        noteModal.classList.add('opacity-0');
        noteModalContent.classList.add('scale-95');
        setTimeout(() => { noteModal.classList.add('hidden'); }, 300);
    };

    const initializeEditor = () => {
        if (document.getElementById('noteEditor') && !easymde) {
            easymde = new EasyMDE({
                element: document.getElementById('noteEditor'),
                spellChecker: false,
                minHeight: '200px',
                maxHeight: '400px',
                toolbar: ["bold", "italic", "heading", "|", "quote", "unordered-list", "ordered-list", "|", "link", "image", "|", "preview", "side-by-side", "fullscreen"],
            });
        }
    };

    // --- DATA FETCHING & RENDERING ---
    const renderPagination = () => {
        kbPaginationEl.innerHTML = '';
        if (filteredNotesData.length <= notesPerPage) return;

        const totalPages = Math.ceil(filteredNotesData.length / notesPerPage);
        let paginationHTML = '';

        // Previous button
        paginationHTML += `
            <button onclick="displayPage(${currentPage - 1})" class="px-3 py-1 rounded-md ${currentPage === 1 ? 'text-gray-400 cursor-not-allowed' : 'hover:bg-gray-200 dark:hover:bg-gray-600'}" ${currentPage === 1 ? 'disabled' : ''}>
                &laquo;
            </button>
        `;

        // Page numbers
        for (let i = 1; i <= totalPages; i++) {
            paginationHTML += `
                <button onclick="displayPage(${i})" class="px-3 py-1 rounded-md ${i === currentPage ? 'bg-blue-600 text-white' : 'hover:bg-gray-200 dark:hover:bg-gray-600'}">
                    ${i}
                </button>
            `;
        }

        // Next button
        paginationHTML += `
            <button onclick="displayPage(${currentPage + 1})" class="px-3 py-1 rounded-md ${currentPage === totalPages ? 'text-gray-400 cursor-not-allowed' : 'hover:bg-gray-200 dark:hover:bg-gray-600'}" ${currentPage === totalPages ? 'disabled' : ''}>
                &raquo;
            </button>
        `;

        kbPaginationEl.innerHTML = paginationHTML;
    };

    const renderNoteList = (notesToRender) => {
        if (filteredNotesData.length === 0) {
            notesListEl.innerHTML = '<p class="text-center text-sm text-gray-500">Không có ghi chú nào.</p>';
            return;
        }
        if (notesToRender.length === 0 && currentPage > 1) {
            // If on a page > 1 and it's empty after a delete, go to previous page
            displayPage(currentPage - 1);
            return;
        }
        notesListEl.innerHTML = notesToRender.map(note => `
            <div id="note-item-${note._id}" onclick="displayNote('${note._id}')" class="p-3 rounded-lg cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 ${note._id === selectedNoteId ? 'bg-blue-50 dark:bg-blue-900/30' : ''}">
                <h4 class="font-semibold text-sm text-gray-800 dark:text-gray-100 truncate">${note.title}</h4>
                <p class="text-xs text-gray-500 dark:text-gray-400">${note.category}</p>
            </div>
        `).join('');
    };

    const displayPage = (page) => {
        currentPage = page;
        const totalPages = Math.ceil(filteredNotesData.length / notesPerPage);
        if (currentPage < 1) currentPage = 1;
        if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;

        const startIndex = (currentPage - 1) * notesPerPage;
        const paginatedNotes = filteredNotesData.slice(startIndex, startIndex + notesPerPage);

        renderNoteList(paginatedNotes);
        renderPagination();
    };

    const displayNote = (noteId) => {
        selectedNoteId = noteId;
        const note = notesData.find(n => n._id === noteId);
        if (!note) return;

        kbWelcomeEl.classList.add('hidden');
        kbDetailEl.classList.remove('hidden');

        noteTitleEl.textContent = note.title;
        noteCategoryBadgeEl.textContent = note.category;
        noteDateEl.textContent = new Date(note.updatedAt).toLocaleString('vi-VN');
        noteBodyEl.innerHTML = marked.parse(note.content);

        // Add copy buttons to code blocks
        noteBodyEl.querySelectorAll('pre').forEach(pre => {
            const code = pre.querySelector('code');
            if (code) {
                const copyBtn = document.createElement('button');
                copyBtn.innerHTML = '<i class="fas fa-copy"></i> Copy';
                copyBtn.className = 'copy-code-btn';
                copyBtn.onclick = () => copyCode(code.innerText);
                pre.appendChild(copyBtn);
            }
        });
        
        document.getElementById('edit-note-btn').onclick = () => editNote(noteId);
        document.getElementById('delete-note-btn').onclick = () => requestDeleteNote(noteId, note.title);

        displayPage(currentPage); // Re-render current page to highlight selection
    };
    
    const copyCode = (text) => {
        navigator.clipboard.writeText(text).then(() => {
            showToast('Đã sao chép vào clipboard!', 'success');
        }, () => {
            showToast('Lỗi khi sao chép!', 'error');
        });
    };

    const fetchNotes = async () => {
        try {
            const res = await fetch('/api/notes');
            if (!res.ok) throw new Error('Failed to fetch notes');
            notesData = await res.json();
            
            const searchTerm = document.getElementById('kbSearchInput').value.toLowerCase();
            if (searchTerm) {
                filteredNotesData = notesData.filter(note => 
                    note.title.toLowerCase().includes(searchTerm) || 
                    note.category.toLowerCase().includes(searchTerm)
                );
            } else {
                filteredNotesData = [...notesData];
            }

            let pageToShow = 1;
            if (selectedNoteId) {
                const noteIndex = filteredNotesData.findIndex(n => n._id === selectedNoteId);
                if (noteIndex !== -1) pageToShow = Math.floor(noteIndex / notesPerPage) + 1;
            }
            displayPage(pageToShow);
        } catch (err) {
            showToast(err.message, 'error');
        }
    };

    const fetchCategories = async () => {
        try {
            const res = await fetch('/api/kb-categories');
            if (!res.ok) throw new Error('Failed to fetch categories');
            categoriesData = await res.json();
            const select = document.getElementById('formNoteCategory');
            select.innerHTML = '<option value="">-- Chọn danh mục --</option>' + categoriesData.map(c => `<option value="${c.name}">${c.name}</option>`).join('');
        } catch (err) {
            showToast(err.message, 'error');
        }
    };

    // --- CRUD ACTIONS ---
    const saveNote = async (event) => {
        event.preventDefault();
        const id = document.getElementById('noteId').value;
        const data = {
            title: document.getElementById('formNoteTitle').value,
            category: document.getElementById('formNoteCategory').value,
            content: easymde.value(),
        };

        const method = id ? 'PUT' : 'POST';
        const url = id ? `/api/notes/${id}` : '/api/notes';

        try {
            const res = await fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();
            if (!res.ok) throw new Error(result.message || 'Lỗi lưu dữ liệu');

            showToast(id ? 'Cập nhật thành công!' : 'Đã thêm bài viết!', 'success');
            
            selectedNoteId = result._id;
            await fetchNotes();
            displayNote(result._id);
            closeNoteModal();
        } catch (err) {
            showToast(err.message, 'error');
        }
    };

    const editNote = (noteId) => {
        const note = notesData.find(n => n._id === noteId);
        if (!note) return;
        openNoteModal(note); // Pass the note object to the modal function
    };

    const requestDeleteNote = (noteId, title) => {
        openConfirmDialog('Xóa bài viết', `Bạn có chắc chắn muốn xóa bài viết <b>${title}</b> không?`, 'danger', async () => {
            try {
                const res = await fetch(`/api/notes/${noteId}`, { method: 'DELETE' });
                if (!res.ok) throw new Error('Lỗi khi xóa');
                
                selectedNoteId = null;
                kbDetailEl.classList.add('hidden');
                kbWelcomeEl.classList.remove('hidden');
                await fetchNotes();
                showToast('Đã xóa bài viết', 'success');
            } catch (err) {
                showToast(err.message, 'error');
            }
        });
    };
    
    // --- SEARCH ---
    const handleSearch = (event) => {
        const searchTerm = event.target.value.toLowerCase();
        filteredNotesData = notesData.filter(note => 
            note.title.toLowerCase().includes(searchTerm) || 
            note.category.toLowerCase().includes(searchTerm)
        );
        displayPage(1);
    };

    // --- INITIALIZATION ---
    document.addEventListener('DOMContentLoaded', () => {
        fetchNotes();
        fetchCategories();
        
        noteForm.addEventListener('submit', saveNote);
        document.getElementById('kbSearchInput').addEventListener('input', handleSearch);
    });
</script>