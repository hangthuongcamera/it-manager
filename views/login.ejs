<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - IT Manager</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { darkMode: 'class' }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="/js/theme.js"></script>
</head>
<body class="bg-gray-100 dark:bg-gray-900 font-sans">
    <div class="min-h-screen flex items-center justify-center p-4">
        <div class="max-w-md w-full bg-white dark:bg-gray-800 rounded-xl shadow-lg p-8 space-y-6">
            <div class="text-center">
                <div class="flex items-center justify-center gap-2 font-bold text-2xl text-blue-600 dark:text-blue-400 mb-2">
                    <i class="fas fa-server"></i>
                    <span>IT Manager</span>
                </div>
                <h2 class="text-xl font-semibold text-gray-700 dark:text-gray-200">Đăng nhập vào tài khoản</h2>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="bg-red-100 dark:bg-red-900/30 border-l-4 border-red-500 text-red-700 dark:text-red-300 p-4 rounded-lg" role="alert">
                    <p><%= error %></p>
                </div>
            <% } %>

            <form class="space-y-6" action="/login" method="POST">
                <div>
                    <label for="username" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Tên đăng nhập</label>
                    <div class="mt-1">
                        <input id="username" name="username" type="text" required value="admin" class="w-full px-3 py-2 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-white">
                    </div>
                </div>
                <div>
                    <label for="password" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Mật khẩu</label>
                    <div class="mt-1">
                        <input id="password" name="password" type="password" required value="password123" class="w-full px-3 py-2 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-white">
                    </div>
                </div>
                <div>
                    <button type="submit" class="w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                        Đăng nhập
                    </button>
                </div>
            </form>
            <p class="text-xs text-center text-gray-500 dark:text-gray-400">
                Sử dụng tài khoản: <strong>admin</strong> / <strong>password123</strong>
            </p>
        </div>
    </div>
</body>
</html>