<!-- Wrapper Chính -->
<div class="bg-white dark:bg-gray-800 p-4 md:p-6 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 relative min-h-[500px]">
    <!-- Toolbar -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
        <h2 class="text-xl font-bold text-gray-800 dark:text-white">Quản lý Loại thiết bị</h2>
        <button onclick="openModal()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2">
            <i class="fas fa-plus"></i> Thêm Loại thiết bị
        </button>
    </div>

    <!-- Hiển thị Bảng (PC) -->
    <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-left border-collapse whitespace-nowrap">
            <thead>
                <tr class="bg-gray-50 dark:bg-gray-700/50 text-gray-600 dark:text-gray-300 text-sm border-b border-gray-200 dark:border-gray-700">
                    <th class="p-3 font-medium">Tên loại thiết bị</th>
                    <th class="p-3 font-medium">Mô tả</th>
                    <th class="p-3 font-medium text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody id="desktop-list" class="divide-y divide-gray-200 dark:divide-gray-700">
                <!-- Render bằng JS -->
            </tbody>
        </table>
    </div>

    <!-- Hiển thị Dạng Card (Mobile) -->
    <div id="mobile-list" class="grid grid-cols-1 gap-4 md:hidden">
        <!-- Render bằng JS -->
    </div>
</div>

<!-- Modal Thêm/Sửa -->
<div id="dataModal" class="fixed inset-0 z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal()"></div>
    <div id="modalContent" class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-lg relative z-10 mx-4 transform scale-95 transition-transform duration-300">
        <div class="p-5 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
            <h3 id="modalTitle" class="text-lg font-bold text-gray-800 dark:text-white">Thêm Loại thiết bị</h3>
            <button type="button" onclick="closeModal()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 focus:outline-none">
                <i class="fas fa-times text-lg"></i>
            </button>
        </div>
        <form id="dataForm" class="p-5 space-y-4">
            <input type="hidden" id="dataId">
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tên loại thiết bị <span class="text-red-500">*</span></label>
                <input type="text" id="dataName" required placeholder="VD: Switch, Router..." class="w-full px-3 py-2 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-white">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Mô tả</label>
                <textarea id="dataDescription" rows="3" placeholder="Mô tả ngắn gọn về loại thiết bị" class="w-full px-3 py-2 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-white"></textarea>
            </div>
            <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-gray-100 dark:border-gray-700">
                <button type="button" onclick="closeModal()" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 rounded-lg transition-colors focus:outline-none">Hủy</button>
                <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors focus:outline-none flex items-center gap-2">
                    <i class="fas fa-save"></i> Lưu thông tin
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // Script for Device Types
    let dataList = [];
    const API_ENDPOINT = '/api/device-types';
    const ITEM_NAME = 'Loại thiết bị';

    const desktopListEl = document.getElementById('desktop-list');
    const mobileListEl = document.getElementById('mobile-list');
    const dataModal = document.getElementById('dataModal');
    const modalContent = document.getElementById('modalContent');
    const dataForm = document.getElementById('dataForm');
    const dataIdInput = document.getElementById('dataId');
    const dataNameInput = document.getElementById('dataName');
    const dataDescriptionInput = document.getElementById('dataDescription');
    const modalTitleEl = document.getElementById('modalTitle');

    window.openModal = () => {
        dataForm.reset();
        dataIdInput.value = '';
        modalTitleEl.textContent = `Thêm ${ITEM_NAME}`;
        dataModal.classList.remove('hidden');
        setTimeout(() => {
            dataModal.classList.remove('opacity-0');
            modalContent.classList.remove('scale-95');
        }, 10);
    };

    window.closeModal = () => {
        dataModal.classList.add('opacity-0');
        modalContent.classList.add('scale-95');
        setTimeout(() => {
            dataModal.classList.add('hidden');
        }, 300);
    };

    const createRow = (item) => `
        <tr id="row-${item._id}" class="hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors text-sm text-gray-800 dark:text-gray-200">
            <td class="p-3 font-semibold item-name">${item.name}</td>
            <td class="p-3 text-gray-600 dark:text-gray-400 item-description">${item.description || ''}</td>
            <td class="p-3 text-right whitespace-nowrap">
                <button onclick="editItem('${item._id}')" class="text-blue-500 hover:text-blue-700 dark:hover:text-blue-400 w-8 h-8 rounded-full hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors" title="Sửa"><i class="fas fa-edit"></i></button>
                <button onclick="requestDeleteItem('${item._id}', '${item.name}')" class="text-red-500 hover:text-red-700 dark:hover:text-red-400 w-8 h-8 rounded-full hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" title="Xóa"><i class="fas fa-trash"></i></button>
            </td>
        </tr>
    `;

    const createCard = (item) => `
        <div id="card-${item._id}" class="bg-gray-50 dark:bg-gray-700/30 p-4 rounded-xl border border-gray-100 dark:border-gray-700">
            <h4 class="font-bold text-gray-800 dark:text-white item-name">${item.name}</h4>
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 item-description">${item.description || 'Không có mô tả'}</p>
            <div class="pt-3 border-t border-gray-200 dark:border-gray-600 flex justify-end gap-2">
                <button onclick="editItem('${item._id}')" class="text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/20 px-2 py-1 rounded transition-colors text-sm"><i class="fas fa-edit"></i> Sửa</button>
                <button onclick="requestDeleteItem('${item._id}', '${item.name}')" class="text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 px-2 py-1 rounded transition-colors text-sm"><i class="fas fa-trash"></i> Xóa</button>
            </div>
        </div>
    `;

    const renderList = () => {
        if (dataList.length === 0) {
            const emptyRow = `<tr><td colspan="3" class="p-6 text-center text-gray-500">Chưa có dữ liệu.</td></tr>`;
            const emptyCard = `<div class="p-6 text-center text-gray-500 border border-dashed rounded-xl">Chưa có dữ liệu.</div>`;
            desktopListEl.innerHTML = emptyRow;
            mobileListEl.innerHTML = emptyCard;
            return;
        }
        desktopListEl.innerHTML = dataList.map(createRow).join('');
        mobileListEl.innerHTML = dataList.map(createCard).join('');
    };

    const fetchData = async () => {
        try {
            const res = await fetch(API_ENDPOINT);
            if (!res.ok) throw new Error('Failed to fetch data');
            dataList = await res.json();
            renderList();
        } catch (err) {
            showToast(err.message || `Lỗi khi tải danh sách ${ITEM_NAME.toLowerCase()}`, 'error');
        }
    };

    const saveData = async (event) => {
        event.preventDefault();
        const id = dataIdInput.value;
        const data = {
            name: dataNameInput.value,
            description: dataDescriptionInput.value,
        };

        const method = id ? 'PUT' : 'POST';
        const url = id ? `${API_ENDPOINT}/${id}` : API_ENDPOINT;

        try {
            const res = await fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();
            if (!res.ok) {
                throw new Error(result.message || 'Lỗi lưu dữ liệu');
            }

            if (id) { // Update
                const index = dataList.findIndex(item => item._id === id);
                if (index !== -1) dataList[index] = result;
                // Sắp xếp lại danh sách sau khi cập nhật để đảm bảo đúng thứ tự
                dataList.sort((a, b) => a.name.localeCompare(b.name));
                showToast('Cập nhật thành công!', 'success');
            } else { // Create
                dataList.push(result);
                // Sắp xếp lại danh sách sau khi thêm mới
                dataList.sort((a, b) => a.name.localeCompare(b.name));
                showToast(`Đã thêm ${ITEM_NAME.toLowerCase()}!`, 'success');
            }
            renderList();
            closeModal();
        } catch (err) {
            showToast(err.message, 'error');
        }
    };

    window.editItem = (id) => {
        const item = dataList.find(i => i._id === id);
        if (!item) return;

        // Bước 1: Điền thông tin của mục cần sửa vào các trường input.
        dataIdInput.value = item._id;
        dataNameInput.value = item.name;
        dataDescriptionInput.value = item.description || '';

        // Bước 2: Cập nhật tiêu đề của modal.
        modalTitleEl.textContent = `Cập nhật ${ITEM_NAME}`;

        // Bước 3: Mở modal. Quan trọng là không gọi hàm openModal() vì nó sẽ reset form.
        // Thay vào đó, chúng ta sao chép logic mở modal từ hàm đó.
        dataModal.classList.remove('hidden');
        setTimeout(() => {
            dataModal.classList.remove('opacity-0');
            modalContent.classList.remove('scale-95');
        }, 10);
    };

    window.requestDeleteItem = (id, name) => {
        openConfirmDialog(`Xóa ${ITEM_NAME}`, `Bạn có chắc chắn muốn xóa <b>${name}</b> không?`, 'danger', async () => {
            try {
                const res = await fetch(`${API_ENDPOINT}/${id}`, { method: 'DELETE' });
                const result = await res.json();
                if (!res.ok) {
                    throw new Error(result.message || 'Lỗi khi xóa');
                }
                dataList = dataList.filter(item => item._id !== id);
                renderList();
                showToast(`Đã xóa ${ITEM_NAME.toLowerCase()}`, 'success');
            } catch (err) {
                showToast(err.message, 'error');
            }
        });
    };

    dataForm.addEventListener('submit', saveData);
    document.addEventListener('DOMContentLoaded', fetchData);
</script>